# ============================================================================
# TANRIC 2.0 configuration
# ----------------------------------------------------------------------------
# Copy this file to `.env` and adjust. The app loads `.env` automatically via
# tanric/config.py, so you never edit code to change configuration.
#
# Precedence: real OS environment variables  >  .env file  >  built-in defaults.
# Never commit a real `.env` (it is gitignored); commit only this `.env.example`.
# ============================================================================

# ----------------------------------------------------------------------------
# STORAGE  ·  choose ONE deployment mode by leaving exactly one block active.
# This single switch is the only difference between on-prem and cloud.
# ----------------------------------------------------------------------------

# --- Mode A: ON-PREM (local filesystem) -------------------------------------
# Data lives on local disk / a mounted volume and never leaves the machine.
# This block is active by default.
TANRIC_STORAGE=local
TANRIC_DATA_ROOT=data

# --- Mode B: CLOUD (S3 / MinIO) ---------------------------------------------
# To switch to cloud: comment out the two lines above, then uncomment this
# block. No code change is needed.
#   - tanric / tanric-secret must match MINIO_ROOT_USER / PASSWORD in
#     docker-compose.cloud.yml.
#   - Use localhost:9000 when running the app/seed script on your host machine.
#   - For REAL AWS S3: set real AWS keys and DELETE the TANRIC_S3_ENDPOINT line
#     so boto3 talks to AWS instead of MinIO.
# TANRIC_STORAGE=object
# TANRIC_S3_BUCKET=tanric-data
# TANRIC_S3_ENDPOINT=http://localhost:9000
# TANRIC_S3_REGION=us-east-1
# AWS_ACCESS_KEY_ID=tanric
# AWS_SECRET_ACCESS_KEY=tanric-secret

# ----------------------------------------------------------------------------
# AUTH / SESSIONS
# ----------------------------------------------------------------------------
# How long a login session stays valid, in seconds (default 8 hours).
TANRIC_SESSION_TTL_SECONDS=28800

# Seed demo accounts (prototype only — production uses a real user store).
# Override these in your local .env so no real password lives in source control.
TANRIC_SEED_USER_PRIMARY_ID=saisadhan
TANRIC_SEED_USER_PRIMARY_NAME=Sai Sadhan Saravanan
TANRIC_SEED_USER_PRIMARY_PASSWORD=sai-password
TANRIC_SEED_USER_SECONDARY_ID=bob
TANRIC_SEED_USER_SECONDARY_NAME=Bob (Lab B)
TANRIC_SEED_USER_SECONDARY_PASSWORD=bob-password
